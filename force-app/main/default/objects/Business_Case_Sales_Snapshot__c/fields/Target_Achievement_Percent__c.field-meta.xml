<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Target_Achievement_Percent__c</fullName>
    <description>Calculated field: (Total Reagent Sales / Target Sales) * 100</description>
    <formula>IF(Target_Sales__c &gt; 0, (Total_Reagent_Sales__c / Target_Sales__c), 0)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Target Achievement %</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
