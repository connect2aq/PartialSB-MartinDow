<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Per_Machine_Sales__c</fullName>
    <description>Calculated field: Total Reagent Sales divided by Machine Count</description>
    <formula>IF(Machine_Count__c &gt; 0, Total_Reagent_Sales__c / Machine_Count__c, 0)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Per Machine Sales</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Currency</type>
</CustomField>
