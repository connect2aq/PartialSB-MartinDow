        }
        
        .subject-label {
            font-weight: bold;
        }
        
        .subject-value {
            font-weight: bold;
            text-decoration: underline;
        }
        
        .intro-text {
            margin: 10px 0 15px 0;
            font-size: 14px;
        }
        
