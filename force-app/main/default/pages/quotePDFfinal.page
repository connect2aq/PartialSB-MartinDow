        .data-table {
            width: 100%;
            border: 3px solid black;
            border-collapse: collapse;
            margin: 15px 0;
        }
        
        .data-table th {
            border: 2px solid black;
            background-color: #6b7c93;
            color: white;
            padding: 8px 5px;
            text-align: left;
            font-weight: bold;
        }
        
