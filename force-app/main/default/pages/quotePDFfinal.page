<apex:page standardController="MD_Quote__c" renderAs="pdf">
<html>
<head>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 12px;
            margin: 20px;
        }
        
        .header-table {
            width: 100%;
            margin-bottom: 20px;
        }
        
        .header-table td {
            vertical-align: top;
        }
        
        .logo-section {
            width: 60%;
        }
        
        .meta-section {
            width: 40%;
